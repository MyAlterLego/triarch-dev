## Copy to bootstrap.config.env (gitignored), then edit.

# ---- Required ---------------------------------------------------------------
GITHUB_ORG="acme-corp"
GITHUB_REPO="acme-app"
DEFAULT_BRANCH="main"

# Three AWS accounts — one per environment. Get from `aws organizations list-accounts`.
AWS_ACCOUNT_ID_DEV="111111111111"
AWS_ACCOUNT_ID_STAGING="222222222222"
AWS_ACCOUNT_ID_PROD="333333333333"
AWS_REGION="us-east-1"

# ---- Teams ------------------------------------------------------------------
TEAM_ENG="engineering"
TEAM_RELEASE_MANAGERS="release-managers"
TEAM_SECURITY="security"
CREATE_TEAMS=1               # 0 if teams already exist

# ---- Optional ---------------------------------------------------------------
CHANGE_TICKET_PREFIX="CHG-"   # used in deploy-prod gating

# ---- Repository variables (set after bootstrap via: gh variable set) --------
# APP_DOMAIN=example.com
# CHANGE_TICKET_PREFIX=CHG-
